import { app } from './Config.js';

let parentContainer = null;
let lizardSheet = null;

// Call once after imageContainer exists
export async function initLizardAnimator(container) {
    parentContainer = container;

    // Load the spritesheet texture
    const texture = await PIXI.Assets.load('assets/lizard_spritesheet.png');
    
    // Slice into frames — adjust these to match your sheet
    const frameWidth = 64;
    const frameHeight = 64;
    const frameCount = 8;
    const frames = [];

    for (let i = 0; i < frameCount; i++) {
        frames.push(
            new PIXI.Texture(texture, 
                new PIXI.Rectangle(i * frameWidth, 0, frameWidth, frameHeight)
            )
        );
    }

    lizardSheet = frames;
}

export function spawnLizard() {
    if (!lizardSheet || !parentContainer) return;

    const lizard = new PIXI.AnimatedSprite(lizardSheet);
    lizard.animationSpeed = 0.15;
    lizard.anchor.set(0.5);
    lizard.play();

    // Start from center of the most recent surrounded group
    // (you could pass coords from ImageSection instead)
    lizard.x = parentContainer.width / 2;
    lizard.y = parentContainer.height / 2;

    parentContainer.addChild(lizard);

    // Pick a random outward direction
    const angle = Math.random() * Math.PI * 2;
    const speed = 1.5 + Math.random() * 1.5;
    const vx = Math.cos(angle) * speed;
    const vy = Math.sin(angle) * speed;

    // Rotate sprite to face movement direction
    lizard.rotation = angle + Math.PI / 2; // adjust offset to match your art

    // Animate each frame
    const ticker = () => {
        lizard.x += vx;
        lizard.y += vy;

        // Remove once offscreen
        const margin = 100;
        if (lizard.x < -margin || lizard.x > parentContainer.width + margin ||
            lizard.y < -margin || lizard.y > parentContainer.height + margin) {
            app.ticker.remove(ticker);
            lizard.destroy();
        }
    };

    app.ticker.add(ticker);
}